{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "box-carousel",
  "title": "Box Carousel",
  "description": "A beautiful 3D rotating box/cube carousel with smooth drag gestures, arrow navigation, auto-play, and custom card rendering.",
  "dependencies": [
    "framer-motion",
    "lucide-react"
  ],
